# URL site public (bắt buộc khi production — SePay gọi callback/IPN về domain này)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- SANDBOX (test, không thu tiền thật) ---
# SEPAY_ENV=sandbox
# SEPAY_MERCHANT_ID=merchant_id_sandbox_tu_my.sepay.vn
# SEPAY_SECRET_KEY=secret_key_sandbox

# --- PRODUCTION (thanh toán thật) ---
# Bước trên my.sepay.vn: liên kết NH → "Chuyển sang Production" → copy Merchant ID + Secret MỚI
SEPAY_ENV=production
SEPAY_MERCHANT_ID=MERCHANT_ID_PRODUCTION
SEPAY_SECRET_KEY=SECRET_KEY_PRODUCTION

# IPN (cấu hình trên my.sepay.vn): https://your-domain.com/api/sepay/ipn
# Không dùng localhost — SePay server không gọi được máy bạn.
