NEXT_PUBLIC_SITE_URL=http://localhost:3000
SEPAY_ENV=sandbox
SEPAY_MERCHANT_ID=YOUR_MERCHANT_ID
SEPAY_SECRET_KEY=YOUR_MERCHANT_SECRET_KEY

# Khi deploy lên Vercel, đổi NEXT_PUBLIC_SITE_URL thành domain public thực tế,
# ví dụ https://your-project.vercel.app hoặc custom domain của bạn.
# Nếu quên đặt biến này, server sẽ cố tự suy ra domain từ request khi có thể,
# nhưng vẫn nên cấu hình rõ ràng ở môi trường production.

# IPN phải là URL đầy đủ, có domain public và phân giải DNS được.
# Không nhập /api/sepay/ipn một mình, cũng không dùng IP private hoặc localhost.
# Ví dụ đúng: https://your-domain.com/api/sepay/ipn